# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

*.csv
*.xlsx
*.docx

# Tina CMS generated files
.tina/__generated__

# Netlify local build artifacts
.netlify/

# Deploy and zip artifacts
deploy-update.zip
*.zip
api_token.txt
deploy_status.json
deploys.json
scratch/

# FTP config files
*.coreftp

# Article images (too large for git — already on cPanel, FTP action excludes this folder)
/public/images/articles/

# Fetch logs
scripts/fetch-log.txt
scripts/fetch-log-live.txt
